{
  "name": "@memory.build/client",
  "version": "0.2.5",
  "description": "Client library for Memory Engine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timescale/memory-engine.git"
  },
  "homepage": "https://memory.build",
  "keywords": [
    "memory-engine",
    "ai",
    "memory",
    "semantic-search",
    "llm",
    "mcp"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": "./index.ts",
      "types": "./index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "*.ts",
    "!*.test.ts"
  ],
  "scripts": {
    "build:js": "../../bun build index.ts --outdir dist --format esm --target node --packages external",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "../../bun run build:js && ../../bun run build:types",
    "prepublishOnly": "../../bun run build"
  },
  "dependencies": {
    "@memory.build/protocol": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "private": false,
  "license": "Apache-2.0"
}
