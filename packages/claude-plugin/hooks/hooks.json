{
  "description": "Memory Engine hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "me claude env",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "me claude hook --event stop",
            "async": true,
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "me claude hook --event session-end",
            "async": true,
            "timeout": 60
          }
        ]
      }
    ]
  }
}
