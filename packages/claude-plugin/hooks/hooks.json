{
  "description": "Memory Engine capture hooks",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "me claude hook --event stop",
            "async": true,
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "me claude hook --event session-end",
            "async": true,
            "timeout": 60
          }
        ]
      }
    ]
  }
}
