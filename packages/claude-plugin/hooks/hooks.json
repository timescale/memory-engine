{
  "description": "Memory Engine capture hooks",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "me claude hook --event user-prompt-submit",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "me claude hook --event stop",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ]
  }
}
