{
  "name": "memory-engine",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "scripts"
  ],
  "scripts": {
    "postinstall": "bun scripts/postinstall.ts",
    "check": "bun run format && bun run lint && bun run typecheck",
    "format": "biome check --linter-enabled=false",
    "format:fix": "biome check --write --linter-enabled=false",
    "lint": "biome check --formatter-enabled=false",
    "lint:fix": "biome check --write --formatter-enabled=false",
    "typecheck": "tsc --noEmit",
    "sandbox:create": "bun scripts/sandbox-create.ts",
    "pg:build": "docker build -t me-postgres -f docker/Dockerfile.postgres docker/",
    "pg": "bun run pg:build && docker run -d --name me-postgres -e POSTGRES_HOST_AUTH_METHOD=trust -p 127.0.0.1:5432:5432 me-postgres",
    "pg:rm": "docker rm -f me-postgres",
    "psql": "psql postgresql://postgres@127.0.0.1:5432/postgres",
    "test": "bun test packages",
    "generate:master-key": "bun scripts/generate-master-key.ts",
    "setup": "bun scripts/setup.ts",
    "build": "bun run --filter '@memory-engine/cli' build",
    "server": "bun run packages/server/index.ts",
    "build:all": "bun scripts/build-all.ts",
    "clean": "rm -rf packages/cli/dist dist"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@biomejs/cli-darwin-arm64": "2.4.6",
    "@biomejs/cli-linux-arm64": "2.4.6",
    "@biomejs/cli-linux-arm64-musl": "2.4.6",
    "@biomejs/cli-linux-x64": "2.4.6",
    "bun-types": "1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
